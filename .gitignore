# ── Python virtual-envs ─────────────────────────────────────────
**/venv/
**/.venv/

# ── Compiled byte-code ─────────────────────────────────────────
*.py[cod]
__pycache__/

# ── OS / editor junk (optional) ────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Large binary captures you don't want in Git ────────────────
# (keep only your tiny test pcaps in samples/)
*.pcap
*.pcapng
!samples/*.pcap         # but DO keep our sample dns_port.pcap
!samples/*.pcapng

